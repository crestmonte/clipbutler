# ClipButler Proxy — required environment variables
# Copy this file to .env for local development (never commit .env)

# Required: Google AI Studio API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Optional: override the default model
GEMINI_MODEL=gemini-2.5-flash

# Required: Stripe secret key (sk_live_... for production, sk_test_... for dev)
STRIPE_SECRET_KEY=

# Required: Stripe webhook signing secret (whsec_...)
# Get this from Stripe Dashboard → Developers → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=

# Set to true ONLY for local testing (returns mock Gemini responses)
DEV_MODE=false

# Only needed when NOT on Railway (Railway sets RAILWAY_PUBLIC_DOMAIN automatically)
SERVICE_URL=

# SQLite database file for subscriber records
SUBSCRIBERS_DB=subscribers.db
