<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<ExtensionManifest Version="7.0" ExtensionBundleId="com.clipbutler.panel"
    ExtensionBundleVersion="1.0.0" ExtensionBundleName="ClipButler">

  <ExtensionList>
    <Extension Id="com.clipbutler.panel.main" Version="1.0.0" />
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <!-- Premiere Pro CC 2022 and above -->
      <Host Name="PPRO" Version="[22.0,99.9]" />
    </HostList>
    <LocaleList>
      <Locale Code="All" />
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="11.0" />
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.clipbutler.panel.main">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <CEFCommandLine>
            <Parameter>--allow-file-access-from-files</Parameter>
            <Parameter>--allow-running-insecure-content</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>ClipButler</Menu>
          <Geometry>
            <Size>
              <Height>600</Height>
              <Width>420</Width>
            </Size>
            <MinSize>
              <Height>400</Height>
              <Width>320</Width>
            </MinSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>

</ExtensionManifest>
