# ClipButler environment variables
# Copy this file to .env for local development
# In production, API keys are stored in the OS keychain via keyring

# Gemini API key (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your_key_here

# Keygen.sh account ID (https://keygen.sh)
KEYGEN_ACCOUNT_ID=your_account_id_here

# Optional: override data directory
# CLIPBUTLER_DATA_DIR=/path/to/data
